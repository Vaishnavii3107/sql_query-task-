-- WHERE CONDITIONS
CREATE TABLE employees (
    emp_id SERIAL PRIMARY KEY,
    name VARCHAR(50),
    department VARCHAR(50),
    salary INT,
    age INT,
    joining_date DATE,
    city VARCHAR(50)
);

