-- Salary > 50000
SELECT * FROM employees
WHERE salary > 50000;

-- Department = IT
SELECT * FROM employees
WHERE department = 'IT';

-- BETWEEN
SELECT * FROM employees
WHERE salary BETWEEN 40000 AND 70000;

-- NULL Values
SELECT * FROM employees
WHERE city IS NULL;

-- LIKE
SELECT * FROM employees
WHERE name LIKE 'A%';

-- AND Condition
SELECT * FROM employees
WHERE department = 'IT' AND salary > 55000;

-- IN
SELECT * FROM employees
WHERE department IN ('HR', 'Finance');

